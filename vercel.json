{
  "functions": {
    "api/**/*.py": {
      "includeFiles": "frontend/public/cities.csv"
    }
  },
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
